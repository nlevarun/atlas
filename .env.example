# Atlas Environment Configuration
# ALL KEYS ARE OPTIONAL - Atlas works 100% FREE without any keys!

# ============================================================================
# LLM Synthesis (OPTIONAL - uses smart templates by default)
# ============================================================================

# Groq (FREE tier: 15 req/min, 6000/day) - https://console.groq.com
# Fastest LLM inference in the world, completely free
GROQ_API_KEY=

# Enable Groq synthesis (set to true if you have GROQ_API_KEY)
USE_GROQ_SYNTHESIS=false

# ============================================================================
# Search APIs (OPTIONAL - agents use realistic mock data by default)
# ============================================================================

# Tavily (FREE tier: 1,000 searches/month) - https://tavily.com
TAVILY_API_KEY=

# ============================================================================
# External Services (OPTIONAL)
# ============================================================================

# GitHub (FREE, better rate limits: 5000/hr) - https://github.com/settings/tokens
# Scopes needed: public_repo, read:org
GITHUB_TOKEN=

# SEC Edgar (FREE, no key needed, just add your email for compliance)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# ============================================================================
# Infrastructure (Docker defaults - no changes needed)
# ============================================================================

DATABASE_URL=postgresql://atlas:atlas_dev@localhost:5432/atlas
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlas_dev
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233

# ============================================================================
# App Configuration
# ============================================================================

# Use real agents (true) or dummy agent for testing (false)
USE_REAL_AGENTS=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Development Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Cost Summary (with all free tiers)
# ============================================================================
# Groq synthesis: $0.00 (free tier)
# Tavily news: $0.00 (1000 free/month)
# SEC Edgar: $0.00 (always free)
# GitHub: $0.00 (always free)
# TOTAL: $0.00/month
#
# Perfect for personal research!
# ============================================================================
